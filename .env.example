# ---- Base de datos (MySQL / XAMPP) ----
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=diferpa_db

# ---- Servidor ----
PORT=3001

# ---- CORS: origen permitido del Frontend ----
CORS_ORIGIN=http://localhost:4200
